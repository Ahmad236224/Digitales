# Google PageSpeed Insights API Key
# Optional, but highly recommended to avoid rate limiting in production.
# Create a local .env.local file and set the real key there:
#
# PAGESPEED_API_KEY=your_google_pagespeed_api_key_here
#
# For details, see: https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# Firebase Web SDK
# Copy these from Firebase Console > Project settings > Your apps > Web app.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
