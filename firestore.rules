rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function validEmail(email) {
      return email is string
        && email.size() <= 254
        && email.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$');
    }

    function validString(value, maxLength) {
      return value is string && value.size() > 0 && value.size() <= maxLength;
    }

    function optionalString(value, maxLength) {
      return value == null || (value is string && value.size() <= maxLength);
    }

    function validSourceDomain(value) {
      return value is string && value.size() > 0 && value.size() <= 120;
    }

    function hasOnlyFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    match /contacts/{contactId} {
      allow create: if hasOnlyFields([
          'name',
          'email',
          'service',
          'message',
          'sourceDomain',
          'createdAt'
        ])
        && validString(request.resource.data.name, 120)
        && validEmail(request.resource.data.email)
        && validString(request.resource.data.service, 160)
        && validString(request.resource.data.message, 5000)
        && validSourceDomain(request.resource.data.sourceDomain)
        && request.resource.data.createdAt == request.time;

      allow read, update, delete: if false;
    }

    match /newsletter_subscribers/{subscriberId} {
      allow create: if hasOnlyFields([
          'type',
          'email',
          'sourceDomain',
          'createdAt'
        ])
        && request.resource.data.type == 'newsletter'
        && validEmail(request.resource.data.email)
        && validSourceDomain(request.resource.data.sourceDomain)
        && request.resource.data.createdAt == request.time;

      allow read, update, delete: if false;
    }

    match /dartx_applications/{applicationId} {
      allow create: if hasOnlyFields([
          'name',
          'email',
          'role',
          'services',
          'budget',
          'createdAt'
        ])
        && validString(request.resource.data.name, 120)
        && validEmail(request.resource.data.email)
        && validString(request.resource.data.role, 160)
        && validString(request.resource.data.services, 1000)
        && validString(request.resource.data.budget, 160)
        && request.resource.data.createdAt == request.time;

      allow read, update, delete: if false;
    }

    match /audit_leads/{leadId} {
      allow create: if hasOnlyFields([
          'name',
          'email',
          'company',
          'phone',
          'industry',
          'budget',
          'url',
          'strategy',
          'score',
          'createdAt',
          'updatedAt'
        ])
        && validString(request.resource.data.name, 120)
        && validEmail(request.resource.data.email)
        && optionalString(request.resource.data.company, 180)
        && optionalString(request.resource.data.phone, 80)
        && optionalString(request.resource.data.industry, 160)
        && optionalString(request.resource.data.budget, 160)
        && validString(request.resource.data.url, 2048)
        && request.resource.data.strategy in ['mobile', 'desktop']
        && request.resource.data.score == null
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'score',
          'updatedAt'
        ])
        && request.resource.data.score is int
        && request.resource.data.score >= 0
        && request.resource.data.score <= 100
        && request.resource.data.updatedAt == request.time;

      allow read, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
